# real .env is gitignored.

# ---------- Database ----------
# Async driver (asyncpg). Local Docker Postgres on port 5433 (5432 often taken).
DATABASE_URL=postgresql+asyncpg://cartiq:cartiq@localhost:5433/cartiq

# ---------- Cache ----------
# Local Redis, or an Upstash rediss:// URL in production.
REDIS_URL=redis://localhost:6379/0

# ---------- Auth (JWT) ----------
# Generate with:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---------- QuickCommerce API ----------
QUICKCOMMERCE_API_KEY=your-quickcommerce-api-key
QUICKCOMMERCE_BASE_URL=https://api.quickcommerceapi.com
# true = return canned mock data instead of calling the paid API.
USE_MOCK_QC=true

# ---------- Gemini (Part 8) ----------
GEMINI_API_KEY=your-google-ai-studio-key
GEMINI_MODEL=gemini-flash-lite-latest

# ---------- Cache TTL ----------
CACHE_TTL_SECONDS=1800

# ---------- CORS ----------
# which domains are allowed to call the API.
CORS_ORIGINS=http://localhost:3000
